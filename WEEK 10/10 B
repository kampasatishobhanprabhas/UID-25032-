<!DOCTYPE html>
<html>
<head>
    <title>Sort Three Numbers</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #a36737, #31a939);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 0;
        }

        .container {
            background: white;
            padding: 30px;
            border-radius: 15px;
            text-align: center;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            width: 300px;
        }

        input {
            width: 80%;
            padding: 10px;
            margin: 8px;
            border-radius: 8px;
            border: 1px solid #ccc;
        }

        button {
            margin-top: 15px;
            padding: 10px 20px;
            border: none;
            background: #4facfe;
            color: white;
            cursor: pointer;
        }
    </style>
</head>

<body>

<div class="container">
    <h2>Sort 3 Numbers</h2>

    <input type="number" id="num1" placeholder="Enter first number"><br>
    <input type="number" id="num2" placeholder="Enter second number"><br>
    <input type="number" id="num3" placeholder="Enter third number"><br>

    <button onclick="sortNumbers()">Sort Numbers</button>
</div>

<script>
function sortNumbers() {

    let a = document.getElementById("num1").value;
    let b = document.getElementById("num2").value;
    let c = document.getElementById("num3").value;

    if (a === "" || b === "" || c === "") {
        alert("Please enter all numbers");
        return;
    }

    a = Number(a);
    b = Number(b);
    c = Number(c);

    let temp;

    if (a > b) {
        temp = a;
        a = b;
        b = temp;
    }

    if (a > c) {
        temp = a;
        a = c;
        c = temp;
    }

    if (b > c) {
        temp = b;
        b = c;
        c = temp;
    }

    alert("Sorted order: " + a + ", " + b + ", " + c);
}
</script>

</body>
</html>