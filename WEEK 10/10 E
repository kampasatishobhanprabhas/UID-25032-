<style>
    body {
        font-family: Arial, sans-serif;
        background: linear-gradient(135deg, #1d976c, #93f9b9);
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        margin: 0;
    }

    .container {
        background: white;
        padding: 30px;
        border-radius: 15px;
        text-align: center;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        width: 320px;
    }

    input {
        width: 80%;
        padding: 10px;
        margin: 6px;
        border-radius: 8px;
        border: 1px solid #ccc;
    }

    button {
        margin-top: 15px;
        padding: 10px 20px;
        border: none;
        background: #4facfe;
        color: white;
        cursor: pointer;
        border-radius: 8px;
    }

    #output {
        margin-top: 15px;
        font-weight: bold;
    }
</style>
<input type="number" id="m1" placeholder="Subject 1"><br>
<input type="number" id="m2" placeholder="Subject 2"><br>
<input type="number" id="m3" placeholder="Subject 3"><br>
<input type="number" id="m4" placeholder="Subject 4"><br>
<input type="number" id="m5" placeholder="Subject 5"><br>
<input type="number" id="m6" placeholder="Subject 6"><br>

<button onclick="calculateGrade()">Calculate Grade</button>

<div id="output"></div>