
<!DOCTYPE html>
<html>
<head>
    <title>Largest Number</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #242f91, #cd1111);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 0;
        }

        .container {
            background: white;
            padding: 30px;
            border-radius: 15px;
            text-align: center;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            width: 300px;
        }

        input {
            width: 80%;
            padding: 10px;
            margin: 8px;
            border-radius: 8px;
            border: 1px solid #2ad18e;
        }

        button {
            margin-top: 15px;
            padding: 10px 20px;
            border: none;
            background: #4facfe;
            color: white;
            cursor: pointer;
        }
    </style>
</head>

<body>

<div class="container">
    <h2>Largest of 5 Numbers</h2>
<h3>Enter 5 numbers</h3>
<h3>All numbers must be unique:</h3>
    <input type="number" id="num1" placeholder="Enter first number"><br>
    <input type="number" id="num2" placeholder="Enter second number"><br>
    <input type="number" id="num3" placeholder="Enter third number"><br>
    <input type="number" id="num4" placeholder="Enter fourth number"><br>
    <input type="number" id="num5" placeholder="Enter fifth number"><br>

    <button onclick="findLargest()">Find Largest</button>
</div>

<script>
function findLargest() {

    let a = document.getElementById("num1").value;
    let b = document.getElementById("num2").value;
    let c = document.getElementById("num3").value;
    let d = document.getElementById("num4").value;
    let e = document.getElementById("num5").value; 

    if (a === "" || b === "" || c === "" || d === "" || e === "") {
        alert("Please enter all numbers");
        return;
    }

    a = Number(a);
    b = Number(b);
    c = Number(c);
    d = Number(d);
    e = Number(e);

    if (a===b || a===c || a===d || a===e ||
        b===c || b===d || b===e ||
        c===d || c===e ||
        d===e) {
        alert("Duplicate numbers not allowed!");
        return;
    }

    let temp = a; // assume a is largest

    if (b > temp) temp = b;
    if (c > temp) temp = c;
    if (d > temp) temp = d;
    if (e > temp) temp = e;

    alert("The largest number is: " + temp);
}
</script>

</body>
</html>